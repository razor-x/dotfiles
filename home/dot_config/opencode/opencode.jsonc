{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "*/opencode/tool-output/*": "allow"
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": {
        "clientId": "Iv23liMsUdPFCRrDC3os",
        "clientSecret": "{env:GITHUB_MCP_CLIENT_SECRET}"
      },
      "enabled": true
    }
  }
}

