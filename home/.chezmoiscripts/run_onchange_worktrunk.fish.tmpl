#!/usr/bin/env fish

# version: {{ output "wt" "--version" }}

if type --query wt; and type --query opencode
    wt config plugins opencode install --yes
else
    echo 'Cannot setup Worktrunk OpenCode plugin: wt or opencode not found.'
    if set --query CODESPACES; and test "$CODESPACES" = true
        return 0
    end
    return 1
end
