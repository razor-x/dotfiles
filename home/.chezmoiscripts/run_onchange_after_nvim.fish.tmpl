#!/usr/bin/env fish

{{ $hash := include (joinPath .chezmoi.sourceDir "dot_config" "exact_nvim" ".lazy-lock.json") | sha256sum -}}

{{ $dir := joinPath .chezmoi.homeDir ".config" "nvim" "doc" -}}
{{- range (glob (printf "%s/*.txt" $dir)) -}}
  {{- $hash = printf "%s%s" $hash (include . | sha256sum) | sha256sum -}}
{{- end -}}

# hash: {{ sha256sum $hash }}

if type --query nvim
    nvim --headless '+Lazy! clean' '+Lazy! restore' +qall
    nvim --headless '+helptags {{ $dir }}' +qall
else
    echo 'Cannot generate Neovim helptags or install plugins: nvim not found.'
    if set --query CODESPACES; and test "$CODESPACES" = true
        return 0
    end
    return 1
end
