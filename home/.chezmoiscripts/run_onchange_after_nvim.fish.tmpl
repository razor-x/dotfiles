#!/usr/bin/env fish

{{ $dir := joinPath .chezmoi.homeDir ".config" "nvim" "doc" -}}
{{ $hash := "" -}}
{{- range (glob (printf "%s/*.txt" $dir)) -}}
  {{- $hash = printf "%s%s" $hash (include . | sha256sum) | sha256sum -}}
{{- end -}}

# hash: {{ sha256sum $hash }}

if type --query nvim
    nvim --clean --headless '+helptags {{ $dir }}' +qall
else
    echo 'Cannot generate Neovim helptags: nvim not found.'
    return 1
end
