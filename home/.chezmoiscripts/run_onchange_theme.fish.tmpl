#!/usr/bin/env fish

fish_config theme choose {{ template "theme/fish" | quote }}

kitten themes --reload-in=all {{ template "theme/kitty" | quote }}

set kitten_config_path "$HOME/.config/kitty"
mkdir -p $kitten_config_path
kitten themes --dump {{ template "theme/kitty" | quote }} > $kitten_config_path/current-theme.conf
